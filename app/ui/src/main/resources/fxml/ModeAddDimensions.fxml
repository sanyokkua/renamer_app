<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.layout.*?>
<?import ua.renamer.app.ui.widget.impl.ItemPositionWithReplacementRadioSelector?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      fx:controller="ua.renamer.app.ui.controller.mode.impl.ModeAddDimensionsController"
      prefHeight="400.0" prefWidth="600.0" spacing="12">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <ItemPositionWithReplacementRadioSelector fx:id="itemPositionRadioSelector" id="itemPositionRadioSelector"
                                              labelValue="%mode_img_vid_dimensions_label_position">
        <VBox.margin>
            <Insets bottom="4"/>
        </VBox.margin>
    </ItemPositionWithReplacementRadioSelector>

    <VBox VBox.vgrow="NEVER" spacing="8">
        <HBox spacing="8">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%mode_img_vid_dimensions_label_left_side" styleClass="label-section"/>
                <ChoiceBox fx:id="leftDimensionChoiceBox" maxWidth="Infinity">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </ChoiceBox>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%mode_img_vid_dimensions_label_separator_between" styleClass="label-section"/>
                <TextField fx:id="dimensionsSeparatorTextField" maxWidth="Infinity"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%mode_img_vid_dimensions_label_right_side" styleClass="label-section"/>
                <ChoiceBox fx:id="rightDimensionChoiceBox" maxWidth="Infinity">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </ChoiceBox>
            </VBox>
        </HBox>

        <Label text="%mode_img_vid_dimensions_label_name_separator" styleClass="label-section"/>
        <TextField fx:id="dimensionsAndFileSeparatorTextField" maxWidth="Infinity"/>
    </VBox>

</VBox>
