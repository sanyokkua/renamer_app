      fx:controller="ua.renamer.app.ui.controller.mode.impl.ModeChangeExtensionController"
      prefHeight="400.0" prefWidth="600.0" spacing="12">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <VBox VBox.vgrow="NEVER" spacing="8">
        <Label text="%mode_change_extension_label_new_extension" styleClass="label-section"/>
        <TextField fx:id="extensionTextField" maxWidth="Infinity"/>
    </VBox>

</VBox>
