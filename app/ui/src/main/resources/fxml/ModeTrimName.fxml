<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.layout.VBox?>
<?import ua.renamer.app.ui.widget.impl.ItemPositionTruncateRadioSelector?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      fx:controller="ua.renamer.app.ui.controller.mode.impl.ModeTrimNameController"
      prefHeight="400.0" prefWidth="600.0" spacing="12">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <ItemPositionTruncateRadioSelector fx:id="itemPositionRadioSelector" id="itemPositionRadioSelector"
                                       labelValue="%mode_truncate_label_position">
        <VBox.margin>
            <Insets bottom="4"/>
        </VBox.margin>
    </ItemPositionTruncateRadioSelector>

    <VBox VBox.vgrow="NEVER" spacing="8">
        <Label fx:id="amountOfSymbolsLabel" text="%mode_truncate_label_amount_of_symbols" styleClass="label-section"/>
        <Spinner fx:id="amountOfSymbolsSpinner" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </Spinner>
    </VBox>

</VBox>
