<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.*?>
<?import javafx.scene.layout.*?>
<?import ua.renamer.app.ui.widget.impl.ItemPositionWithReplacementRadioSelector?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      fx:controller="ua.renamer.app.ui.controller.mode.impl.ModeAddDatetimeController"
      prefHeight="400.0" prefWidth="600.0" spacing="12">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <ItemPositionWithReplacementRadioSelector fx:id="dateTimePositionInTheNameRadioSelector"
                                              id="dateTimePositionInTheNameRadioSelector"
                                              labelValue="%mode_datetime_label_position">
        <VBox.margin>
            <Insets bottom="4"/>
        </VBox.margin>
    </ItemPositionWithReplacementRadioSelector>

    <VBox VBox.vgrow="NEVER" spacing="8">
        <Label fx:id="datetimeAndNameSeparatorLabel" text="%mode_datetime_label_datetime_name_separator"
               styleClass="label-section"/>
        <TextField fx:id="dateTimeAndNameSeparatorTextField" maxWidth="Infinity"/>

        <Label text="%mode_datetime_label_date_format" styleClass="label-section"/>
        <ChoiceBox fx:id="dateFormatChoiceBox" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </ChoiceBox>

        <Label text="%mode_datetime_label_time_format" styleClass="label-section"/>
        <ChoiceBox fx:id="timeFormatChoiceBox" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </ChoiceBox>

        <Label text="%mode_datetime_label_date_time_format" styleClass="label-section"/>
        <ChoiceBox fx:id="dateTimeFormatChoiceBox" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </ChoiceBox>

        <CheckBox fx:id="useUppercaseForAmPmCheckBox" text="%mode_datetime_label_use_am_pm_in_uppercase"
                  maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </CheckBox>

        <Label text="%mode_datetime_label_time_source" styleClass="label-section"/>
        <ChoiceBox fx:id="dateTimeSourceChoiceBox" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </ChoiceBox>

        <CheckBox fx:id="useFallbackDateTimeCheckBox" text="%mode_datetime_label_use_fallback" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </CheckBox>

        <CheckBox fx:id="useCustomDateTimeAsFallbackCheckBox" text="%mode_datetime_label_use_fallback_custom_date"
                  maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </CheckBox>
    </VBox>

    <VBox fx:id="dateTimePicker" VBox.vgrow="NEVER" spacing="4">
        <Label text="%date_picker_date" styleClass="label-section"/>
        <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
        <HBox spacing="8">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%date_picker_hour" styleClass="label-section"/>
                <Spinner fx:id="hourSpinner" maxWidth="Infinity"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%date_picker_minute" styleClass="label-section"/>
                <Spinner fx:id="minuteSpinner" maxWidth="Infinity"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="%date_picker_second" styleClass="label-section"/>
                <Spinner fx:id="secondSpinner" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </VBox>

</VBox>
