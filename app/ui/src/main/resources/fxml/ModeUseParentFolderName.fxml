<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.layout.VBox?>
<?import ua.renamer.app.ui.widget.impl.ItemPositionRadioSelector?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      fx:controller="ua.renamer.app.ui.controller.mode.impl.ModeUseParentFolderNameController"
      prefHeight="400.0" prefWidth="600.0" spacing="12">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <ItemPositionRadioSelector fx:id="itemPositionRadioSelector" id="itemPositionRadioSelector"
                               labelValue="%mode_parent_folders_label_position">
        <VBox.margin>
            <Insets bottom="4"/>
        </VBox.margin>
    </ItemPositionRadioSelector>

    <VBox VBox.vgrow="NEVER" spacing="8">
        <Label text="%mode_parent_folders_label_number" styleClass="label-section"/>
        <Spinner fx:id="parentsNumberSpinner" maxWidth="Infinity">
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </Spinner>

        <Label text="%mode_parent_folders_label_separator" styleClass="label-section"/>
        <TextField fx:id="fileNameSeparatorTextField" maxWidth="Infinity"/>
    </VBox>

</VBox>
